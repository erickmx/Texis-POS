# ==========================================
# Root Monorepo .gitignore
# ==========================================

# env files
.env
.env.*
!.env.example

# Editor/IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# ==========================================
# Go (backend/)
# ==========================================
backend/*.exe
backend/*.exe~
backend/*.dll
backend/*.so
backend/*.dylib
backend/*.test
backend/*.out
backend/coverage.*
backend/*.coverprofile
backend/profile.cov

# env file
backend/.env

# ==========================================
# Node.js / Next.js (ui/)
# ==========================================
ui/node_modules/
ui/.next/
ui/out/
ui/.turbo
ui/next-env.d.ts
ui/npm-debug.log*
ui/yarn-debug.log*
ui/yarn-error.log*
ui/.yarn-cache/

# ==========================================
# Tauri (desktop/)
# ==========================================
desktop/node_modules/
desktop/dist/
desktop/src-tauri/target/
desktop/src-tauri/gen/
desktop/npm-debug.log*
desktop/yarn-debug.log*
desktop/yarn-error.log*

# Tauri build outputs
desktop/src-tauri/**/*.app
desktop/src-tauri/**/*.dmg
desktop/src-tauri/**/*.AppImage
desktop/src-tauri/**/*.deb
desktop/src-tauri/**/*.rpm
desktop/src-tauri/**/*.msi
desktop/src-tauri/**/*.exe

# ==========================================
# TypeScript
# ==========================================
*.tsbuildinfo

# ==========================================
# Testing
# ==========================================
coverage/
.nyc_output/
