{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "supabase": {
            "type": "remote",
            "url": "https://mcp.supabase.com/mcp?project_ref=yhqgkyzunbolqrsrsqfx&features=docs%2Cdatabase%2Cdebugging%2Cdevelopment%2Cbranching%2Cstorage",
            "enabled": true
        },
        "context7": {
            "type": "remote",
            "url": "https://mcp.context7.com/mcp",
            "headers": {
                "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
            },
            "enabled": true
        },
        "chrome-devtools": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "chrome-devtools-mcp@latest"
            ]
        }
    }
}